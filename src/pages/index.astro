---
import Layout from "../layouts/Layout.astro";
import Tile from "../components/Tile.astro";
import chelyabinsk from "../media/chelyabinsk.jpg";
import kazan from "../media/kazan.jpg";
import moscow from "../media/moscow.jpg";
import nizhnyNovgorod from "../media/nizhny-novgorod.jpg";
import novosibirsk from "../media/novosibirsk.jpg";
import omsk from "../media/omsk.jpg";
import saintPetersburg from "../media/saint-petersburg.jpg";
import samara from "../media/samara.jpg";
import yekaterinburg from "../media/yekaterinburg.jpg";
---

<Layout title="Russian City Facts Tiles">
  <h1>10 Boring Facts About Russian Cities</h1>

  <div class="controls">
    <button class="toggle-button"> Toggle Dark Theme </button>
  </div>

  <div class="grid">
    <Tile
      city="Moscow"
      img={moscow}
      text="Moscow is the largest city in Europe, with over 12 million residents and more than 200 metro stations."
    />
    <Tile
      city="St. Petersburg"
      img={saintPetersburg}
      text="St. Petersburg was founded by Tsar Peter the Great in 1703 and is built on around 100 islands connected by hundreds of bridges."
    />
    <Tile
      city="Novosibirsk"
      img={novosibirsk}
      text="Novosibirsk is the largest city in Siberia and home to the country’s “Silicon Valley” cluster near Akademgorodok."
    />
    <Tile
      city="Kazan"
      img={kazan}
      text="Kazan, capital of Tatarstan, blends Russian Orthodox churches with Muslim mosques, reflecting its mixed cultural heritage."
    />
    <Tile
      city="Yekaterinburg"
      img={yekaterinburg}
      text="Yekaterinburg lies on the border of Europe and Asia and is famous as the place where the last Russian tsar, Nicholas II, was executed."
    />
    <Tile
      city="Nizhny Novgorod"
      img={nizhnyNovgorod}
      text="Nizhny Novgorod has the longest staircase in Russia—the Chkalov Stairs, with 560 steps leading down to the Volga River."
    />
    <Tile
      city="Chelyabinsk"
      img={chelyabinsk}
      text="Chelyabinsk is known worldwide for the 2013 meteor explosion that exploded over the city with the force of about 30 Hiroshima bombs."
    />
    <Tile
      city="Omsk"
      img={omsk}
      text="Omsk was once a place of exile for Fyodor Dostoevsky and now hosts one of Russia’s oldest regional museums."
    />
    <Tile
      city="Samara"
      img={samara}
      text="Samara served as the “reserve capital” of the Soviet Union during World War II when many government offices were moved there."
    />
  </div>

  <footer>Generated from general knowledge about Russian cities.</footer>
</Layout>

<style>
  * {
    box-sizing: border-box;
  }

  h1 {
    text-align: center;
    color: var(--h1-color);
    margin-bottom: 30px;
  }

  .controls {
    text-align: center;
    margin-bottom: 20px;
  }

  .toggle-button {
    padding: 8px 16px;
    border: none;
    border-radius: 6px;
    background: #3498db;
    color: #fff;
    cursor: pointer;
    font-size: 0.95rem;
  }

  .toggle-button:hover {
    background: #2980b9;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  footer {
    margin-top: 40px;
    text-align: center;
    font-size: 0.85em;
    color: var(--text-muted);
  }
</style>
