---
const { text, img, city } = Astro.props;
---

<div class="tile" style={{ "--bg": `url(${img.src})` }}>
  <p>{text}</p>
</div>

<style>
  .tile {
    background: var(--tile-overlay), var(--bg);
    background-size: cover;
    border-radius: 12px;
    aspect-ratio: 1 / 1;
    padding: 16px 16px 12px;
    box-shadow: 0 4px 8px var(--shadow);
    transition:
      transform 0.2s,
      border-color 0.2s,
      box-shadow 0.2s,
      background-color 0.3s;
  }

  .tile:nth-child(2n + 1) {
    filter: hue-rotate(90deg);
  }

  .tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px var(--shadow-hover);
  }

  .tile p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.5;
  }
</style>
